#
# Mail (IMAP) credentials for live mail integration tests.
# Used by `tests/mail/test_mail_client_integration.py`,
# `tests/auth/test_auth_verify_email_e2e.py`,
# `tests/ui/auth/test_register_verify_email_e2e.py`, and
# `tests/ui/interview/test_onboarding_flow_e2e.py` (registration → IMAP → verify → onboarding).
#
# Example for Yandex Mail:
# MAIL_HOST=imap.yandex.ru
# MAIL_PORT=993
# MAIL_FOLDER=INBOX
# MAIL_EMAIL=verify-test@yeahub.ru
# MAIL_PASSWORD=<app_password>  # use an application password for "Mail / IMAP POP3 SMTP"
#
MAIL_HOST=
MAIL_PORT=993
MAIL_FOLDER=INBOX
MAIL_EMAIL=
MAIL_PASSWORD=

# Verified user credentials for subscription/payment tests
VERIFIED_USER_EMAIL=
VERIFIED_USER_PASSWORD=

# Set to 1 to enable live IMAP tests (off by default).
RUN_MAIL_INTEGRATION=0

# Optional overrides for same-email re-register tail in `test_register_and_verify_email_e2e`
# (defaults live in `tests/ui/flows/same_email_retry_config.py`: max wait 120 s, poll 4 s).
# REGISTER_SAME_EMAIL_RETRY_MAX_WAIT_SECONDS=0   # fast path: only assert cooldown toast (skip full re-register)
# REGISTER_SAME_EMAIL_RETRY_MAX_WAIT_SECONDS=180 # slower backend
# REGISTER_SAME_EMAIL_RETRY_POLL_INTERVAL_SECONDS=4
# REGISTER_SAME_EMAIL_API_PROBE=1  # default in tests/mail/verification_flow.py; set 0 for blind sleep only
# Legacy if MAX_WAIT unset: REGISTER_SAME_EMAIL_RETRY_AFTER_SECONDS=120

TMS_URL=
TMS_PRIVATE_TOKEN=
TMS_PROJECT_ID=
TMS_CONFIGURATION_ID=
TMS_TEST_RUN_NAME=
TMS_ADAPTER_MODE=2
# Optional Test IT adapter (see pyproject.toml [testit] and testit-adapter-pytest README):
# TMS_AUTOMATIC_UPDATION_LINKS_TO_TEST_CASES=true  # update links manual case <-> autotest when reporting
# TMS_AUTOMATIC_CREATION_TEST_CASES=false          # do not auto-create duplicate manual cases (default)

APP_BASE_URL=https://app.yeatwork.ru
