#
# Mail (IMAP) credentials for live mail integration tests.
# Used by `tests/mail/test_mail_client_integration.py`,
# `tests/auth/test_auth_verify_email_e2e.py`, and
# `tests/ui/auth/test_register_verify_email_e2e.py` (registration → IMAP → verify-email).
#
# Example for Yandex Mail:
# MAIL_HOST=imap.yandex.ru
# MAIL_PORT=993
# MAIL_FOLDER=INBOX
# MAIL_EMAIL=verify-test@yeahub.ru
# MAIL_PASSWORD=<app_password>  # use an application password for "Mail / IMAP POP3 SMTP"
#
MAIL_HOST=
MAIL_PORT=993
MAIL_FOLDER=INBOX
MAIL_EMAIL=
MAIL_PASSWORD=

# Verified user credentials for subscription/payment tests
VERIFIED_USER_EMAIL=
VERIFIED_USER_PASSWORD=

# Set to 1 to enable live IMAP tests (off by default).
RUN_MAIL_INTEGRATION=0

# Optional: second signup with same email after delete — backend `user.user.email.limited_period`.
# unset / 0 = fast path (assert error toast only).
# REGISTER_SAME_EMAIL_RETRY_MAX_WAIT_SECONDS=120   # total wait before one UI submit (no repeated submit — avoids race/toast «уже существует»)
# REGISTER_SAME_EMAIL_RETRY_POLL_INTERVAL_SECONDS=4  # chunk size for that wait only (3–5), not between signUp clicks
# REGISTER_SAME_EMAIL_API_PROBE=1  # 1 (default): poll POST /auth/signUp without Bearer until 201 or budget — exit early like prod; 0 = blind sleep only
# Legacy alias (if MAX_WAIT unset): REGISTER_SAME_EMAIL_RETRY_AFTER_SECONDS=120
# On success, test removes second user via DELETE users/:id (API teardown).

TMS_URL=
TMS_PRIVATE_TOKEN=
TMS_PROJECT_ID=
TMS_CONFIGURATION_ID=
TMS_TEST_RUN_NAME=
TMS_ADAPTER_MODE=2
# Optional Test IT adapter (see pyproject.toml [testit] and testit-adapter-pytest README):
# TMS_AUTOMATIC_UPDATION_LINKS_TO_TEST_CASES=true  # update links manual case <-> autotest when reporting
# TMS_AUTOMATIC_CREATION_TEST_CASES=false          # do not auto-create duplicate manual cases (default)

APP_BASE_URL=https://app.yeatwork.ru
